{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "MONGODB_DB": "@mongodb_db",
    "JWT_SECRET": "@jwt_secret",
    "ADMIN_TOKEN": "@admin_token",
    "NEXT_PUBLIC_ADMIN_TOKEN": "@next_public_admin_token"
  }
}
